# ImADHD 설정 예시. 복사해서 .env 로 만들고 실제 값 채울 것.
# .env 는 .gitignore 에 의해 절대 커밋되지 않음.

# ===== Telegram =====
# @BotFather 에서 발급받은 봇 토큰
TELEGRAM_BOT_TOKEN=

# 제어 허용 chat id (본인 user id). @userinfobot 에서 확인. 비우면 모두 허용(권장X).
TELEGRAM_ALLOWED_CHAT_ID=

# ===== 라우터 =====
# 터미널 슬롯 최대 개수
IMADHD_MAX_SLOTS=6

# 런타임 데이터 디렉토리 (registry.json, offset.txt 저장 위치). 비우면 기본경로.
IMADHD_DATA_DIR=

# 기본 입력 transport: sendkeys_win | (future: tmux)
IMADHD_TRANSPORT=sendkeys_win

# 답변 마커 (CC 가 답변 말단에 출력할 문구)
IMADHD_REPLY_MARKER=텔레그램으로 답변
