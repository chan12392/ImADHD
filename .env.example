# ImADHD 설정 예시. 복사해서 .env 로 만들고 실제 값 채울 것.
# .env 는 .gitignore 에 의해 절대 커밋되지 않음.

# ===== Telegram =====
# @BotFather 에서 발급받은 봇 토큰
TELEGRAM_BOT_TOKEN=

# 제어 허용 chat id (본인 user id). @userinfobot 에서 확인.
# ★ 필수(fail-closed): 비우면 봇이 기동하지 않음. 봇 토큰만 있으면 누구나
#   터미널을 제어할 수 있으므로 반드시 본인 user id 를 지정할 것.
TELEGRAM_ALLOWED_CHAT_ID=

# [dev 전용] chat id 없이 로컬 테스트 시 1 로 설정하면 모든 chat 허용.
# 공개/배포 봇에서는 절대 켜지 말 것(누구나 제어 가능).
IMADHD_ALLOW_ANY_CHAT=

# ===== 라우터 =====
# 터미널 슬롯 최대 개수
IMADHD_MAX_SLOTS=6

# 런타임 데이터 디렉토리 (registry.json, offset.txt 저장 위치). 비우면 기본경로.
IMADHD_DATA_DIR=

# 기본 입력 transport: sendkeys_win (Windows) | tmux_linux (Linux).
# 비워두면 플랫폼 자동 감지 (Windows→sendkeys_win, Linux→tmux_linux).
IMADHD_TRANSPORT=

# 답변 마커 (CC 가 답변 말단에 출력할 문구)
IMADHD_REPLY_MARKER=[A.D.H.D]

# [Windows 전용] 주입 방식: paste(클립보드+Ctrl+V, 빠름, 기본) | type(문자별 SendInput, 레거시)
IMADHD_INJECT_METHOD=paste
